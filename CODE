<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        @page { size: A4; margin: 10mm; }
        body { font-family: sans-serif; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .box { border: 1px solid #eee; padding: 10px; text-align: center; height: 42mm; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .label { font-size: 12px; font-weight: bold; margin-bottom: 5px; }
        .url { font-size: 7px; color: #999; word-break: break-all; margin-top: 5px; }
    </style>
</head>
<body>
    <script>
        const base = "https://cynthiatsang-afk.github.io/Vote/page1?room=21090328&seat=";
        const groups = ["G1", "G2", "G3", "G4", "G5", "G6"];
        groups.forEach(g => {
            for(let i=1; i<=4; i++) {
                let id = g + "-" + i;
                document.write(`<div class="box"><div class="label">座位：${id}</div><div id="qr-${id}"></div><div class="url">${id}</div></div>`);
                new QRCode(document.getElementById("qr-"+id), { text: base + id, width: 100, height: 100 });
            }
        });
        window.onload = () => { setTimeout(() => window.print(), 500); };
    </script>
</body>
</html>
